    "@uiw/react-codemirror": "^4.25.9",
    "antd": "^5.28.0",
    "dayjs": "^1.11.13",
    "klinecharts": "^9.8.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
